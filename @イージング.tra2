@Aベジェ
--twopoint
--timecontrol
--param:方向(In0/Out1/InOut2),2
--param:秒数基準(始端0/終端1),0
--param:所要時間(0で全体),0.0
--param:始端影響度(%),33
--param:終端影響度(%),33

local ease_dir, time_dir, sec, p1, p2 = obj.getpoint("param")

local index, _ = math.modf(obj.getpoint("index"))
local st_time = obj.getpoint("time", index)
local ed_time = obj.getpoint("time", index + 1)
local cur_time = obj.getpoint("timecontrol", "time")

local progress = 0
if sec <= 0 then
    progress = obj.getpoint("timecontrol", "value")
else
    if time_dir == 0 then progress = (cur_time - st_time) / sec
    else progress = (cur_time - (ed_time - sec)) / sec end
end

if progress >= 1.0 then return obj.getpoint(index + 1) end
if progress <= 0.0 then return obj.getpoint(index) end

local x1, y1, x2, y2 = 0, 0, 1, 1
local inf1 = math.max(0, math.min(1, p1 / 100))
local inf2 = math.max(0, math.min(1, p2 / 100))
if ease_dir == 0 then x1 = inf1
elseif ease_dir == 1 then x2 = 1 - inf2
else x1 = inf1; x2 = 1 - inf2 end

local t0, t1, ct = 0, 1, progress
for i = 1, 12 do
    local it = 1 - ct
    local x = 3 * it * it * ct * x1 + 3 * it * ct * ct * x2 + ct * ct * ct
    if x < progress then t0 = ct else t1 = ct end
    ct = (t0 + t1) * 0.5
end
local it = 1 - ct
local y = 3 * it * it * ct * y1 + 3 * it * ct * ct * y2 + ct * ct * ct

local st = obj.getpoint(index)
local ed = obj.getpoint(index + 1)
return st + (ed - st) * y


@バウンス
--twopoint
--timecontrol
--param:方向(In0/Out1/InOut2),1
--param:秒数基準(始端0/終端1),0
--param:所要時間(0で全体),0.0
--param:反発係数(倍率%)[標準100],100

local ease_dir, time_dir, sec, b_cor = obj.getpoint("param")

local index, _ = math.modf(obj.getpoint("index"))
local st_time = obj.getpoint("time", index)
local ed_time = obj.getpoint("time", index + 1)
local cur_time = obj.getpoint("timecontrol", "time")

local progress = 0
if sec <= 0 then
    progress = obj.getpoint("timecontrol", "value")
else
    if time_dir == 0 then progress = (cur_time - st_time) / sec
    else progress = (cur_time - (ed_time - sec)) / sec end
end

if progress >= 1.0 then return obj.getpoint(index + 1) end
if progress <= 0.0 then return obj.getpoint(index) end

local cor = b_cor / 100
local function outBounce(t)
    if t < 1 / 2.75 then return 7.5625 * t * t
    elseif t < 2 / 2.75 then t = t - 1.5 / 2.75 return 7.5625 * t * t * cor + 0.75
    elseif t < 2.5 / 2.75 then t = t - 2.25 / 2.75 return 7.5625 * t * t * cor * cor + 0.9375
    else t = t - 2.625 / 2.75 return 7.5625 * t * t * cor * cor * cor + 0.984375 end
end
local function inBounce(t) return 1 - outBounce(1 - t) end

local y = 0
if ease_dir == 0 then y = inBounce(progress)
elseif ease_dir == 1 then y = outBounce(progress)
else
    if progress < 0.5 then y = inBounce(progress * 2) * 0.5
    else y = outBounce(progress * 2 - 1) * 0.5 + 0.5 end
end

local st = obj.getpoint(index)
local ed = obj.getpoint(index + 1)
return st + (ed - st) * y


@エラスティック
--twopoint
--timecontrol
--param:方向(In0/Out1/InOut2),1
--param:秒数基準(始端0/終端1),0
--param:所要時間(0で全体),0.0
--param:振幅(大きいほど大揺れ),1.0
--param:周期(小さいほど細かく振動),0.3

local ease_dir, time_dir, sec, amp, period = obj.getpoint("param")

local index, _ = math.modf(obj.getpoint("index"))
local st_time = obj.getpoint("time", index)
local ed_time = obj.getpoint("time", index + 1)
local cur_time = obj.getpoint("timecontrol", "time")

local progress = 0
if sec <= 0 then
    progress = obj.getpoint("timecontrol", "value")
else
    if time_dir == 0 then progress = (cur_time - st_time) / sec
    else progress = (cur_time - (ed_time - sec)) / sec end
end

if progress >= 1.0 then return obj.getpoint(index + 1) end
if progress <= 0.0 then return obj.getpoint(index) end

local local_amp = math.max(0.1, amp)
local local_period = math.max(0.05, period)

local function outElastic(t)
    local s = local_period / (2 * math.pi) * math.asin(1 / local_amp)
    return local_amp * math.pow(2, -10 * t) * math.sin((t - s) * (2 * math.pi) / local_period) + 1
end
local function inElastic(t)
    local s = local_period / (2 * math.pi) * math.asin(1 / local_amp)
    t = t - 1
    return -(local_amp * math.pow(2, 10 * t) * math.sin((t - s) * (2 * math.pi) / local_period))
end

local y = 0
if ease_dir == 0 then y = inElastic(progress)
elseif ease_dir == 1 then y = outElastic(progress)
else
    if progress < 0.5 then
        local s = local_period / (2 * math.pi) * math.asin(1 / local_amp)
        local t = progress * 2 - 1
        y = -0.5 * (local_amp * math.pow(2, 10 * t) * math.sin((t - s) * (2 * math.pi) / local_period))
    else
        local s = local_period / (2 * math.pi) * math.asin(1 / local_amp)
        local t = progress * 2 - 1
        y = local_amp * math.pow(2, -10 * t) * math.sin((t - s) * (2 * math.pi) / local_period) * 0.5 + 1
    end
end

local st = obj.getpoint(index)
local ed = obj.getpoint(index + 1)
return st + (ed - st) * y


@バック
--twopoint
--timecontrol
--param:方向(In0/Out1/InOut2),1
--param:秒数基準(始端0/終端1),0
--param:所要時間(0で全体),0.0
--param:オーバーシュート量,1.70158

local ease_dir, time_dir, sec, s = obj.getpoint("param")

local index, _ = math.modf(obj.getpoint("index"))
local st_time = obj.getpoint("time", index)
local ed_time = obj.getpoint("time", index + 1)
local cur_time = obj.getpoint("timecontrol", "time")

local progress = 0
if sec <= 0 then
    progress = obj.getpoint("timecontrol", "value")
else
    if time_dir == 0 then progress = (cur_time - st_time) / sec
    else progress = (cur_time - (ed_time - sec)) / sec end
end

if progress >= 1.0 then return obj.getpoint(index + 1) end
if progress <= 0.0 then return obj.getpoint(index) end

local y = 0
if ease_dir == 0 then
    y = progress * progress * ((s + 1) * progress - s)
elseif ease_dir == 1 then
    local t = progress - 1
    y = t * t * ((s + 1) * t + s) + 1
else
    local t = progress * 2
    local s2 = s * 1.525
    if t < 1 then
        y = 0.5 * (t * t * ((s2 + 1) * t - s2))
    else
        t = t - 2
        y = 0.5 * (t * t * ((s2 + 1) * t + s2) + 2)
    end
end

local st = obj.getpoint(index)
local ed = obj.getpoint(index + 1)
return st + (ed - st) * y


@イクスポネンシャル
--twopoint
--timecontrol
--param:方向(In0/Out1/InOut2),1
--param:秒数基準(始端0/終端1),0
--param:所要時間(0で全体),0.0

local ease_dir, time_dir, sec = obj.getpoint("param")

local index, _ = math.modf(obj.getpoint("index"))
local st_time = obj.getpoint("time", index)
local ed_time = obj.getpoint("time", index + 1)
local cur_time = obj.getpoint("timecontrol", "time")

local progress = 0
if sec <= 0 then
    progress = obj.getpoint("timecontrol", "value")
else
    if time_dir == 0 then progress = (cur_time - st_time) / sec
    else progress = (cur_time - (ed_time - sec)) / sec end
end

if progress >= 1.0 then return obj.getpoint(index + 1) end
if progress <= 0.0 then return obj.getpoint(index) end

local y = 0
if ease_dir == 0 then
    y = math.pow(2, 10 * (progress - 1))
elseif ease_dir == 1 then
    y = -math.pow(2, -10 * progress) + 1
else
    if progress < 0.5 then
        y = math.pow(2, 10 * (progress * 2 - 1)) * 0.5
    else
        y = (-math.pow(2, -10 * (progress * 2 - 1)) + 2) * 0.5
    end
end

local st = obj.getpoint(index)
local ed = obj.getpoint(index + 1)
return st + (ed - st) * y


@サイン
--twopoint
--timecontrol
--param:方向(In0/Out1/InOut2),1
--param:秒数基準(始端0/終端1),0
--param:所要時間(0で全体),0.0

local ease_dir, time_dir, sec = obj.getpoint("param")

local index, _ = math.modf(obj.getpoint("index"))
local st_time = obj.getpoint("time", index)
local ed_time = obj.getpoint("time", index + 1)
local cur_time = obj.getpoint("timecontrol", "time")

local progress = 0
if sec <= 0 then
    progress = obj.getpoint("timecontrol", "value")
else
    if time_dir == 0 then progress = (cur_time - st_time) / sec
    else progress = (cur_time - (ed_time - sec)) / sec end
end

if progress >= 1.0 then return obj.getpoint(index + 1) end
if progress <= 0.0 then return obj.getpoint(index) end

local y = 0
if ease_dir == 0 then
    y = 1 - math.cos(progress * math.pi * 0.5)
elseif ease_dir == 1 then
    y = math.sin(progress * math.pi * 0.5)
else
    y = -(math.cos(math.pi * progress) - 1) * 0.5
end

local st = obj.getpoint(index)
local ed = obj.getpoint(index + 1)
return st + (ed - st) * y


@クアドラティック
--twopoint
--timecontrol
--param:方向(In0/Out1/InOut2),1
--param:秒数基準(始端0/終端1),0
--param:所要時間(0で全体),0.0

local ease_dir, time_dir, sec = obj.getpoint("param")

local index, _ = math.modf(obj.getpoint("index"))
local st_time = obj.getpoint("time", index)
local ed_time = obj.getpoint("time", index + 1)
local cur_time = obj.getpoint("timecontrol", "time")

local progress = 0
if sec <= 0 then
    progress = obj.getpoint("timecontrol", "value")
else
    if time_dir == 0 then progress = (cur_time - st_time) / sec
    else progress = (cur_time - (ed_time - sec)) / sec end
end

if progress >= 1.0 then return obj.getpoint(index + 1) end
if progress <= 0.0 then return obj.getpoint(index) end

local y = 0
if ease_dir == 0 then
    y = progress * progress
elseif ease_dir == 1 then
    y = progress * (2 - progress)
else
    if progress < 0.5 then
        y = 2 * progress * progress
    else
        y = 1 - math.pow(-2 * progress + 2, 2) * 0.5
    end
end

local st = obj.getpoint(index)
local ed = obj.getpoint(index + 1)
return st + (ed - st) * y


@サーキュラー
--twopoint
--timecontrol
--param:方向(In0/Out1/InOut2),1
--param:秒数基準(始端0/終端1),0
--param:所要時間(0で全体),0.0

local ease_dir, time_dir, sec = obj.getpoint("param")

local index, _ = math.modf(obj.getpoint("index"))
local st_time = obj.getpoint("time", index)
local ed_time = obj.getpoint("time", index + 1)
local cur_time = obj.getpoint("timecontrol", "time")

local progress = 0
if sec <= 0 then
    progress = obj.getpoint("timecontrol", "value")
else
    if time_dir == 0 then progress = (cur_time - st_time) / sec
    else progress = (cur_time - (ed_time - sec)) / sec end
end

if progress >= 1.0 then return obj.getpoint(index + 1) end
if progress <= 0.0 then return obj.getpoint(index) end

local y = 0
if ease_dir == 0 then
    y = 1 - math.sqrt(1 - math.pow(progress, 2))
elseif ease_dir == 1 then
    y = math.sqrt(1 - math.pow(progress - 1, 2))
else
    if progress < 0.5 then
        y = (1 - math.sqrt(1 - math.pow(2 * progress, 2))) * 0.5
    else
        y = (math.sqrt(1 - math.pow(-2 * progress + 2, 2)) + 1) * 0.5
    end
end

local st = obj.getpoint(index)
local ed = obj.getpoint(index + 1)
return st + (ed - st) * y
